{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "git": {
    "deploymentEnabled": false
  },
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "dist/server/**",
      "regions": ["fra1"],
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/"
    }
  ]
}
